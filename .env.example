# ==========================================================================
# InstaChat — variáveis de ambiente
# Copie este arquivo para .env.local e preencha conforme formos criando as
# contas. NADA aqui vai para o navegador: são todas variáveis de servidor.
# ==========================================================================

# --- Endereço público do app (sem barra no final) ---
# Em desenvolvimento local: http://localhost:3000
# Em produção: https://SEU-APP.vercel.app
APP_URL=http://localhost:3000

# --- Supabase (banco) — pegamos no painel do Supabase ---
# Project Settings > Data API > Project URL
SUPABASE_URL=
# Project Settings > API Keys > service_role  (SECRETA, só no servidor!)
SUPABASE_SERVICE_ROLE_KEY=

# --- App do Instagram na Meta for Developers ---
# "ID do app do Instagram" (é o client_id do OAuth)
INSTAGRAM_APP_ID=
# "Chave secreta do app do Instagram" (SECRETA)
INSTAGRAM_APP_SECRET=

# --- Webhook ---
# Você inventa uma frase secreta qualquer aqui e cadastra igualzinha na Meta.
# Serve para a Meta provar que o webhook é seu no handshake.
WEBHOOK_VERIFY_TOKEN=

# --- Proteção dos endpoints internos (drenar fila / renovar token) ---
# Uma senha aleatória longa. O pg_cron do Supabase envia ela no cabeçalho.
CRON_SECRET=

# --- Senha do painel ---
# Protege /painel por senha. Em produção, DEFINA um valor. Vazio = painel
# aberto (só use vazio em desenvolvimento local).
PANEL_PASSWORD=

# --- Opcionais (self-host) ---
# E-mail de contato mostrado nas páginas públicas de privacidade/exclusão.
CONTACT_EMAIL=
# Nome do app (caso queira renomear na sua instância).
APP_NAME=InstaChat
